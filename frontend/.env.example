# Supabase project (required)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API base URL.
# Leave empty in production — relative URLs are proxied by Vercel.
# Do NOT set this to the backend IP in production: it bypasses the Vercel
# proxy, bakes the IP into the client bundle, and breaks CORS.
VITE_API_URL=

# Optional: Stripe publishable key for client-side Stripe.js.
# Not required today — checkout redirects to Stripe-hosted page via the
# backend /api/checkout endpoint. Set this if you migrate to Payment Elements
# or Embedded Checkout.
VITE_STRIPE_PUBLISHABLE_KEY=
