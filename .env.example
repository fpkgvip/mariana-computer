# Mariana Computer — Environment Variables
# Copy to .env and fill in actual values

# ─── LLM Gateway (unified API for Anthropic / OpenAI / DeepSeek) ────────────
LLM_GATEWAY_API_KEY=your_llm_gateway_key_here
LLM_GATEWAY_BASE_URL=https://api.llmgateway.io/v1
DEEPSEEK_API_KEY=your_deepseek_key_here

# ─── Data APIs ──────────────────────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_api_key_here
UNUSUAL_WHALES_API_KEY=your_unusual_whales_key_here
FRED_API_KEY=your_fred_api_key_here

# ─── Infrastructure (auto-generated by deploy.sh) ──────────────────────────
POSTGRES_USER=mariana
POSTGRES_PASSWORD=change_me_to_random_32_char
POSTGRES_DB=mariana
POSTGRES_DSN=postgresql://mariana:change_me_to_random_32_char@postgresql:5432/mariana
REDIS_URL=redis://redis:6379/0

# ─── Budget defaults (USD) ──────────────────────────────────────────────────
BUDGET_TASK_HARD_CAP=400.0
BUDGET_BRANCH_HARD_CAP=75.0
BUDGET_BRANCH_INITIAL=5.0

# ─── Paths (inside Docker container) ───────────────────────────────────────
DATA_ROOT=/data/mariana

# ─── Stripe billing (required for paid plans) ──────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Test keys (sk_test_/pk_test_) are fine for staging; live keys for prod.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret from https://dashboard.stripe.com/webhooks (whsec_...)
# Point webhook URL to: https://<api-host>/api/billing/webhook
# When empty, webhook endpoint rejects all calls (fail-closed security).
STRIPE_WEBHOOK_SECRET=
# Price IDs from Stripe Products (price_...). Must exist in the Stripe account
# that matches STRIPE_SECRET_KEY. Without these, /api/checkout returns 400.
STRIPE_PRICE_INDIVIDUAL=
STRIPE_PRICE_ENTERPRISE=

# ─── Supabase (auth + profiles + credits) ──────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service key enables direct table writes from the server; when empty the
# server falls back to anon key + SECURITY DEFINER RPCs (works but limited).
SUPABASE_SERVICE_KEY=
